extends: default

ignore: |
  .venv/
  .git/
  .pytest_cache/
  .ruff_cache/
  .mypy_cache/
  htmlcov/
  dist/
  .cache/
  .playwright-mcp/

rules:
  line-length: disable
  document-start: disable
  comments-indentation: disable
  truthy:
    check-keys: false
  indentation:
    indent-sequences: consistent
